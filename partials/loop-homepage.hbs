<article class="feed {{visibility}} {{post_class}}">

    <div class="feed-calendar">
        <span class="feed-calendar-date">{{date published_at format="DD.MM.YYYY"}}{{#if primary_author}} — {{primary_author.name}}{{/if}}</span>
    </div>

    <h2 class="feed-title">{{title}}</h2>

    <div class="feed-right">
        {{> "icons/star"}}
        <div class="feed-length">
            {{reading_time minute=(t "1 min read") minutes=(t "% min read")}}
        </div>
    </div>

    {{> "icons/chevron-right"}}

    <a class="u-permalink" href="{{url}}" aria-label="{{title}}"></a>

</article>
