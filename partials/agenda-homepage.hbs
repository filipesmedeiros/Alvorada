{{#get "posts" filter="tag:hash-agenda" limit="5" order="published_at desc" as |agenda_items|}}
{{#if agenda_items}}
<div class="gh-feed gh-canvas agenda-homepage">
    <h2 class="feed-section-title">{{t "Agenda"}}</h2>
    {{#foreach agenda_items}}
    <article class="feed public">
        <div class="feed-calendar">
            <span class="feed-calendar-day">{{date published_at format="DD"}}</span>
            <span class="feed-calendar-month">{{date published_at format="MMM"}}</span>
            <span class="feed-calendar-year">'{{date published_at format="YY"}}</span>
        </div>
        <h2 class="feed-title">{{title}}</h2>
        <div class="feed-right">
            <div class="feed-length"></div>
        </div>
        {{> "icons/chevron-right"}}
        <a class="u-permalink" href="{{url}}" aria-label="{{title}}"></a>
    </article>
    {{/foreach}}
    <a href="/agenda/" class="agenda-homepage-viewall">{{t "View all →"}}</a>
</div>

<style>
.feed-section-title {
    padding-bottom: 1rem;
    margin-bottom: 0;
    font-size: 1.5rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    border-bottom: 1px solid var(--light-gray-color);
}
.agenda-homepage-viewall {
    display: inline-block;
    padding: 1.5rem 0;
    font-size: 1.4rem;
    color: var(--secondary-text-color);
    text-decoration: none;
    transition: opacity 0.2s;
}
.agenda-homepage-viewall:hover {
    opacity: 0.7;
}
.agenda-homepage {
    margin-top: 4rem;
    margin-bottom: -2rem;
}
.agenda-homepage .feed-title {
    white-space: normal;
    overflow: visible;
    text-overflow: unset;
}
</style>
{{/if}}
{{/get}}
